# ============================================================
# WoTAgent Prototype — Environment Configuration
# ============================================================
# Copy this file to .env and adjust as needed.
# All settings have safe defaults — you can start with an empty .env.

# --- LLM (OpenAI-compatible backend, e.g. DeepSeek) ---
# Model name. deepseek-v4-flash supports tool calls natively.
LLM_MODEL=deepseek-v4-flash
# DeepSeek uses this base URL. For OpenAI change to https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com
# Your API key (required only when USE_MOCK_LLM=0)
OPENAI_API_KEY=your-api-key-here

# --- Thinking Mode ---
# Enable DeepSeek's chain-of-thought reasoning before each response.
# Toggle at runtime in the REPL with:  /think on  /think off
ENABLE_THINKING=true

# --- Streaming Mode ---
# Stream tokens progressively in the REPL (vs. waiting for the full response).
# Toggle at runtime with:  /stream on  /stream off
# Even when OFF, thinking content and tool events still appear live.
ENABLE_STREAMING=true

# --- Mock Mode ---
# Set to 1 to bypass the real LLM and use rule-based mocks.
# Useful for testing / demo without an API key.
USE_MOCK_LLM=0

# --- Embeddings (for RAG) ---
# Provider: "hf" (HuggingFace) or "openai" (text-embedding-3-small)
EMBED_PROVIDER=hf
# Model name: BAAI/bge-small-zh-v1.5 for Chinese, or your preferred model
EMBED_MODEL=BAAI/bge-small-zh-v1.5
# Cache directory for HuggingFace models
HF_HOME=./models
